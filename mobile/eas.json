{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "simulator": {
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "ios": {
        "buildConfiguration": "Release"
      },
      "android": {
        "buildType": "app-bundle"
      }
    },
    "play": {
      "channel": "play",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_PLAY_BUILD": "1"
      },
      "android": {
        "buildType": "app-bundle"
      }
    },
    "play-apk": {
      "distribution": "internal",
      "channel": "play",
      "env": {
        "EXPO_PUBLIC_PLAY_BUILD": "1"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
