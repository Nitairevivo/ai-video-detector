# AI Video Detector — environment variables
# Copy this to .env for local development
# Set these in Railway dashboard: Settings → Variables

# Google Gemini Vision API (free tier — 15 requests/min, 1500/day)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database path (Railway sets this automatically via volume mount)
# DB_PATH=/data/aivd.db

# ── Bots ──────────────────────────────────────────────────────────────────────

# Telegram bot (runs in-process with the API server when set)
# TELEGRAM_BOT_TOKEN=123456:ABC...
# Self-hosted Bot API server — lifts the 20MB file limit to 2GB
# (github.com/tdlib/telegram-bot-api)
# TELEGRAM_API_BASE=http://telegram-bot-api:8081

# WhatsApp Business Cloud API (Meta developer console → WhatsApp)
# WHATSAPP_TOKEN=EAAG...            # permanent system-user access token
# WHATSAPP_PHONE_NUMBER_ID=1234567890
# WHATSAPP_VERIFY_TOKEN=any-secret-you-choose   # webhook handshake

# ── Billing (optional — only needed for paid API keys) ───────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_BIZ=price_...
# STRIPE_PRICE_ENT=price_...
# STRIPE_PRICE_ULTRA=price_...

# ── Ops ───────────────────────────────────────────────────────────────────────
# Error monitoring (free account: sentry.io)
# SENTRY_DSN=https://...@o0.ingest.sentry.io/0

# ── Training (train_forever.py) ───────────────────────────────────────────────
# Where downloaded training videos are cached (default: ./dataset_cache)
# VERIFAI_DATASET_DIR=/data/dataset
# Real-footage supplement source: https://www.pexels.com/api/
# PEXELS_API_KEY=...
# Allow train_forever to push the retrained model to master itself (off by default)
# VERIFAI_AUTOPUSH=0
