{
  "manifest_version": 3,
  "name": "VerifAI — AI Video Detector",
  "version": "2.0.0",
  "description": "Detects AI-generated, AI-edited, and authentic videos on TikTok, Instagram, YouTube and more. One click — instant result.",

  "permissions": [
    "activeTab",
    "clipboardRead",
    "storage",
    "contextMenus",
    "notifications"
  ],

  "host_permissions": [
    "https://www.tiktok.com/*",
    "https://vm.tiktok.com/*",
    "https://www.instagram.com/*",
    "https://www.youtube.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.reddit.com/*",
    "https://www.facebook.com/*",
    "https://fb.watch/*",
    "https://www.snapchat.com/*",
    "https://vimeo.com/*",
    "https://www.twitch.tv/*",
    "https://www.dailymotion.com/*",
    "https://streamable.com/*",
    "https://ai-video-detector-production-a305.up.railway.app/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.tiktok.com/*",
        "https://vm.tiktok.com/*",
        "https://www.instagram.com/*",
        "https://www.youtube.com/*",
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.reddit.com/*",
        "https://www.facebook.com/*",
        "https://fb.watch/*",
        "https://www.snapchat.com/*",
        "https://vimeo.com/*",
        "https://www.twitch.tv/*",
        "https://www.dailymotion.com/*",
        "https://streamable.com/*"
      ],
      "js": ["content/inject.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
