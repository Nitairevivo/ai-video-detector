{
  "manifest_version": 3,
  "name": "AI Video Detector",
  "version": "1.1.0",
  "description": "Automatically flags AI-generated videos on TikTok, Instagram, YouTube, Twitter, Reddit and Facebook.",

  "permissions": [
    "activeTab",
    "clipboardRead",
    "storage"
  ],

  "host_permissions": [
    "https://www.tiktok.com/*",
    "https://www.instagram.com/*",
    "https://www.youtube.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.reddit.com/*",
    "https://www.facebook.com/*",
    "https://web.telegram.org/*",
    "https://ai-video-detector-production-a305.up.railway.app/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.tiktok.com/*",
        "https://www.instagram.com/*",
        "https://www.youtube.com/*",
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.reddit.com/*",
        "https://www.facebook.com/*",
        "https://web.telegram.org/*"
      ],
      "js": ["content/inject.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
